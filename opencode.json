  "provider": {
    "modal": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "Modal GLM-5",
      "options": {
        "baseURL": "https://api.us-west-2.modal.direct/v1"
      },
      "models": {
        "zai-org/GLM-5-FP8": {
          "name": "GLM-5",
          "limit": {
            "context": 200000,
            "output": 128000
          }
        }
      }
    },
    "minimax": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "MiniMax via OpenCode Zen",
      "options": {
        "baseURL": "https://opencode.ai/zen/v1"
      },
      "models": {
        "minimax-m2.5-free": {
          "name": "MiniMax M2.5 Free",
          "limit": {
            "context": 1000000,
            "output": 8000
