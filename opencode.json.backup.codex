{
  "$schema": "https://opencode.ai/config.json",
"model": "openai/gpt-5.4",
  "mcp": {
    "context7": {
      "type": "remote",
      "url": "https://mcp.context7.com/mcp"
    },
    "exa": {
      "type": "remote",
      "url": "https://mcp.exa.ai/mcp",
      "enabled": true
    },
    "jcodemunch": {
      "type": "local",
      "command": [
        "uvx",
        "jcodemunch-mcp"
      ],
      "enabled": true
    }
  },
  "plugin": [
    "opencode-skills",
    "opencode-pty",
    "micode",
    "@tarquinen/opencode-dcp@latest",
    "@plannotator/opencode",
    "opencode-devcontainers"
  ],

  "agent": {
    "planner": {
      "description": "Expert planning specialist for complex features and refactoring. Use for implementation planning, architectural changes, or complex refactoring.",
      "model": "kimi/kimi-k2.5",
      "mode": "subagent",
      "prompt": "{file:/home/kytusdevenn/everything-claude-code/.opencode/prompts/agents/planner.txt}",
      "tools": {
        "read": true,
        "bash": true,
        "write": false,
        "edit": false
      }
    },
    "architect": {
      "description": "Software architecture specialist for system design, scalability, and technical decision-making.",
      "model": "kimi/kimi-k2.5",
      "mode": "subagent",
      "prompt": "{file:/home/kytusdevenn/everything-claude-code/.opencode/prompts/agents/architect.txt}",
      "tools": {
        "read": true,
        "bash": true,
        "write": false,
        "edit": false
      }
    },
    "brainstormer": {
      "model": "openai/gpt-5.4"
    },
    "code-reviewer": {
      "description": "Expert code review specialist. Reviews code for quality, security, and maintainability. Use immediately after writing or modifying code.",
      "model": "openai/gpt-5.4",
      "thinking": "high",
      "mode": "subagent",
      "prompt": "{file:/home/kytusdevenn/everything-claude-code/.opencode/prompts/agents/code-reviewer.txt}",
      "tools": {
        "read": true,
        "bash": true,
        "write": false,
        "edit": false
      }
    },
    "security-reviewer": {
      "description": "Security vulnerability detection and remediation specialist. Use after writing code that handles user input, authentication, API endpoints, or sensitive data.",
      "model": "openai/gpt-5.4",
      "thinking": "xhigh",
      "mode": "subagent",
      "prompt": "{file:/home/kytusdevenn/everything-claude-code/.opencode/prompts/agents/security-reviewer.txt}",
      "tools": {
        "read": true,
        "bash": true,
        "write": true,
        "edit": true
      }
    },
    "tdd-guide": {
      "description": "Test-Driven Development specialist enforcing write-tests-first methodology. Use when writing new features, fixing bugs, or refactoring code. Ensures 80%+ test coverage.",
      "model": "openai/gpt-5.3-codex",
      "thinking": "medium",
      "mode": "subagent",
      "prompt": "{file:/home/kytusdevenn/everything-claude-code/.opencode/prompts/agents/tdd-guide.txt}",
      "tools": {
        "read": true,
        "write": true,
        "edit": true,
        "bash": true
      }
    },
    "build-error-resolver": {
      "description": "Build and TypeScript error resolution specialist. Use when build fails or type errors occur. Fixes build/type errors only with minimal diffs.",
      "model": "openai/gpt-5.3-codex-spark",
      "thinking": "low",
      "mode": "subagent",
      "prompt": "{file:/home/kytusdevenn/everything-claude-code/.opencode/prompts/agents/build-error-resolver.txt}",
      "tools": {
        "read": true,
        "write": true,
        "edit": true,
        "bash": true
      }
    },
    "e2e-runner": {
      "description": "End-to-end testing specialist using Playwright. Generates, maintains, and runs E2E tests for critical user flows.",
      "model": "openai/gpt-5.3-codex",
      "thinking": "low",
      "mode": "subagent",
      "prompt": "{file:/home/kytusdevenn/everything-claude-code/.opencode/prompts/agents/e2e-runner.txt}",
      "tools": {
        "read": true,
        "write": true,
        "edit": true,
        "bash": true
      }
    },
    "doc-updater": {
      "description": "Documentation and codemap specialist. Use for updating codemaps and documentation.",
      "model": "openai/gpt-5.4",
      "thinking": "low",
      "mode": "subagent",
      "prompt": "{file:/home/kytusdevenn/everything-claude-code/.opencode/prompts/agents/doc-updater.txt}",
      "tools": {
        "read": true,
        "write": true,
        "edit": true,
        "bash": true
      }
    },
    "refactor-cleaner": {
      "description": "Dead code cleanup and consolidation specialist. Use for removing unused code, duplicates, and refactoring.",
      "model": "kilocode/minimax/minimax-m2.5-free",
      "mode": "subagent",
      "prompt": "{file:/home/kytusdevenn/everything-claude-code/.opencode/prompts/agents/refactor-cleaner.txt}",
      "tools": {
        "read": true,
        "write": true,
        "edit": true,
        "bash": true
      }
    },
    "go-reviewer": {
      "description": "Expert Go code reviewer specializing in idiomatic Go, concurrency patterns, error handling, and performance.",
      "model": "openai/gpt-5.4",
      "thinking": "medium",
      "mode": "subagent",
      "prompt": "{file:/home/kytusdevenn/everything-claude-code/.opencode/prompts/agents/go-reviewer.txt}",
      "tools": {
        "read": true,
        "bash": true,
        "write": false,
        "edit": false
      }
    },
    "go-build-resolver": {
      "description": "Go build, vet, and compilation error resolution specialist. Fixes Go build errors with minimal changes.",
      "model": "openai/gpt-5.3-codex-spark",
      "thinking": "low",
      "mode": "subagent",
      "prompt": "{file:/home/kytusdevenn/everything-claude-code/.opencode/prompts/agents/go-build-resolver.txt}",
      "tools": {
        "read": true,
        "write": true,
        "edit": true,
        "bash": true
      }
    },
    "database-reviewer": {
      "description": "PostgreSQL database specialist for query optimization, schema design, security, and performance. Incorporates Supabase best practices.",
      "model": "openai/gpt-5.4",
      "thinking": "medium",
      "mode": "subagent",
      "prompt": "{file:/home/kytusdevenn/everything-claude-code/.opencode/prompts/agents/database-reviewer.txt}",
      "tools": {
        "read": true,
        "write": true,
        "edit": true,
        "bash": true
      }
    },
    "rust-reviewer": {
      "description": "Expert Rust code reviewer for idiomatic patterns, ownership, lifetimes, and memory safety.",
      "model": "openai/gpt-5.4",
      "thinking": "high",
      "mode": "subagent",
      "prompt": "{file:/home/kytusdevenn/everything-claude-code/.opencode/prompts/agents/rust-reviewer.txt}",
      "tools": {
        "read": true,
        "bash": true,
        "write": false,
        "edit": false
      }
    },
    "rust-clippy-fmt-check-tester": {
      "description": "Rust build, clippy, fmt, and test error resolution specialist.",
      "model": "openai/gpt-5.3-codex-spark",
      "thinking": "low",
      "mode": "subagent",
      "prompt": "{file:/home/kytusdevenn/everything-claude-code/.opencode/prompts/agents/rust-clippy-fmt-check-tester.txt}",
      "tools": {
        "read": true,
        "bash": true,
        "write": true,
        "edit": true
      }
    }
  },
  "command": {
    "plan": {
      "description": "Create a detailed implementation plan for complex features",
      "template": "{file:/home/kytusdevenn/everything-claude-code/.opencode/commands/plan.md}\n\n$ARGUMENTS",
      "agent": "planner",
      "subtask": true
    },
    "tdd": {
      "description": "Enforce TDD workflow with 80%+ test coverage",
      "template": "{file:/home/kytusdevenn/everything-claude-code/.opencode/commands/tdd.md}\n\n$ARGUMENTS",
      "agent": "tdd-guide",
      "subtask": true
    },
    "code-review": {
      "description": "Review code for quality, security, and maintainability",
      "template": "{file:/home/kytusdevenn/everything-claude-code/.opencode/commands/code-review.md}\n\n$ARGUMENTS",
      "agent": "code-reviewer",
      "subtask": true
    },
    "security": {
      "description": "Run comprehensive security review",
      "template": "{file:/home/kytusdevenn/everything-claude-code/.opencode/commands/security.md}\n\n$ARGUMENTS",
      "agent": "security-reviewer",
      "subtask": true
    },
    "build-fix": {
      "description": "Fix build and TypeScript errors with minimal changes",
      "template": "{file:/home/kytusdevenn/everything-claude-code/.opencode/commands/build-fix.md}\n\n$ARGUMENTS",
      "agent": "build-error-resolver",
      "subtask": true
    },
    "e2e": {
      "description": "Generate and run E2E tests with Playwright",
      "template": "{file:/home/kytusdevenn/everything-claude-code/.opencode/commands/e2e.md}\n\n$ARGUMENTS",
      "agent": "e2e-runner",
      "subtask": true
    },
    "refactor-clean": {
      "description": "Remove dead code and consolidate duplicates",
      "template": "{file:/home/kytusdevenn/everything-claude-code/.opencode/commands/refactor-clean.md}\n\n$ARGUMENTS",
      "agent": "refactor-cleaner",
      "subtask": true
    },
    "orchestrate": {
      "description": "Orchestrate multiple agents for complex tasks",
      "template": "{file:/home/kytusdevenn/everything-claude-code/.opencode/commands/orchestrate.md}\n\n$ARGUMENTS",
      "agent": "planner",
      "subtask": true
    },
    "learn": {
      "description": "Extract patterns and learnings from session",
      "template": "{file:/home/kytusdevenn/everything-claude-code/.opencode/commands/learn.md}\n\n$ARGUMENTS"
    },
    "checkpoint": {
      "description": "Save verification state and progress",
      "template": "{file:/home/kytusdevenn/everything-claude-code/.opencode/commands/checkpoint.md}\n\n$ARGUMENTS"
    },
    "verify": {
      "description": "Run verification loop",
      "template": "{file:/home/kytusdevenn/everything-claude-code/.opencode/commands/verify.md}\n\n$ARGUMENTS"
    },
    "eval": {
      "description": "Run evaluation against criteria",
      "template": "{file:/home/kytusdevenn/everything-claude-code/.opencode/commands/eval.md}\n\n$ARGUMENTS"
    },
    "update-docs": {
      "description": "Update documentation",
      "template": "{file:/home/kytusdevenn/everything-claude-code/.opencode/commands/update-docs.md}\n\n$ARGUMENTS",
      "agent": "doc-updater",
      "subtask": true
    },
    "update-codemaps": {
      "description": "Update codemaps",
      "template": "{file:/home/kytusdevenn/everything-claude-code/.opencode/commands/update-codemaps.md}\n\n$ARGUMENTS",
      "agent": "doc-updater",
      "subtask": true
    },
    "test-coverage": {
      "description": "Analyze test coverage",
      "template": "{file:/home/kytusdevenn/everything-claude-code/.opencode/commands/test-coverage.md}\n\n$ARGUMENTS",
      "agent": "tdd-guide",
      "subtask": true
    },
    "setup-pm": {
      "description": "Configure package manager",
      "template": "{file:/home/kytusdevenn/everything-claude-code/.opencode/commands/setup-pm.md}\n\n$ARGUMENTS"
    },
    "go-review": {
      "description": "Go code review",
      "template": "{file:/home/kytusdevenn/everything-claude-code/.opencode/commands/go-review.md}\n\n$ARGUMENTS",
      "agent": "go-reviewer",
      "subtask": true
    },
    "go-test": {
      "description": "Go TDD workflow",
      "template": "{file:/home/kytusdevenn/everything-claude-code/.opencode/commands/go-test.md}\n\n$ARGUMENTS",
      "agent": "tdd-guide",
      "subtask": true
    },
    "go-build": {
      "description": "Fix Go build errors",
      "template": "{file:/home/kytusdevenn/everything-claude-code/.opencode/commands/go-build.md}\n\n$ARGUMENTS",
      "agent": "go-build-resolver",
      "subtask": true
    },
    "skill-create": {
      "description": "Generate skills from git history",
      "template": "{file:/home/kytusdevenn/everything-claude-code/.opencode/commands/skill-create.md}\n\n$ARGUMENTS"
    },
    "instinct-status": {
      "description": "View learned instincts",
      "template": "{file:/home/kytusdevenn/everything-claude-code/.opencode/commands/instinct-status.md}\n\n$ARGUMENTS"
    },
    "instinct-import": {
      "description": "Import instincts",
      "template": "{file:/home/kytusdevenn/everything-claude-code/.opencode/commands/instinct-import.md}\n\n$ARGUMENTS"
    },
    "instinct-export": {
      "description": "Export instincts",
      "template": "{file:/home/kytusdevenn/everything-claude-code/.opencode/commands/instinct-export.md}\n\n$ARGUMENTS"
    },
    "evolve": {
      "description": "Cluster instincts into skills",
      "template": "{file:/home/kytusdevenn/everything-claude-code/.opencode/commands/evolve.md}\n\n$ARGUMENTS"
    },
    "rust-review": {
      "description": "Review Rust code for idiomatic patterns",
      "template": "{file:/home/kytusdevenn/everything-claude-code/.opencode/commands/rust-review.md}\n\n$ARGUMENTS",
      "agent": "rust-reviewer",
      "subtask": true
    },
    "rust-clippy-fmt-check": {
      "description": "Fix Rust clippy, fmt, and test errors",
      "template": "{file:/home/kytusdevenn/everything-claude-code/.opencode/commands/rust-clippy-fmt-check.md}\n\n$ARGUMENTS",
      "agent": "rust-clippy-fmt-check-tester",
      "subtask": true
    }
  },
  "provider": {
    "modal": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "Modal GLM-5",
      "options": {
        "baseURL": "https://api.us-west-2.modal.direct/v1"
      },
      "models": {
        "zai-org/GLM-5-FP8": {
          "name": "GLM-5",
          "limit": {
            "context": 200000,
            "output": 128000
          }
        }
      }
    },
    "minimax": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "MiniMax via OpenCode Zen",
      "options": {
        "baseURL": "https://opencode.ai/zen/v1"
      },
      "models": {
        "minimax-m2.5-free": {
          "name": "MiniMax M2.5 Free",
          "limit": {
            "context": 1000000,
            "output": 8000
          }
        }
      }
    },
    "kilocode": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "KiloCode",
      "options": {
        "baseURL": "https://api.kilo.ai/api/gateway"
      },
      "models": {
        "minimax/minimax-m2.5:free": {
          "name": "MiniMax M2.5 Free",
          "limit": {
            "context": 1000000,
            "output": 8000
          }
        }
      }
    },
    "nvidia": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "NVIDIA NIM",
      "options": {
        "baseURL": "https://integrate.api.nvidia.com/v1",
        "apiKey": "${NVIDIA_API_KEY}"
      },
      "models": {
        "nvidia/deepseek-ai/deepseek-v3.2": {
          "name": "DeepSeek V3.2",
          "limit": {
            "context": 128000,
            "output": 16384
          },
          "costPerMillionTokens": {
            "input": 0.50,
            "output": 1.50
          }
        }
      }
    },
    "openai": {
      "npm": "@ai-sdk/openai",
      "name": "OpenAI",
      "options": {
        "baseURL": "https://api.openai.com/v1"
      },
      "models": {
        "gpt-5.4": {
          "name": "GPT-5.4",
          "limit": {
            "context": 128000,
            "output": 16384
          }
        },
        "gpt-5.3-codex": {
          "name": "GPT-5.3 Codex",
          "limit": {
            "context": 128000,
            "output": 16384
          }
        },
        "gpt-5.3-codex-spark": {
          "name": "GPT-5.3 Codex Spark",
          "limit": {
            "context": 128000,
            "output": 16384
          }
        }
      }
    }
  },
  "permission": {
    "mcp_*": "ask"
  },
  "experimental": {
    "preemptive_compaction_threshold": false
  }
}
